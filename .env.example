# WealthDesk environment variables
# Copy this file to .env and fill in your actual keys.
#
# Windows:  copy .env.example .env
# Mac/Linux: cp .env.example .env
#
# IMPORTANT: .env is in .gitignore. Never commit it to GitHub.
# If you accidentally push a real API key, rotate it immediately.

# --- Required from Session 1 ---
GROQ_API_KEY=your_Groq_api_key_here
# Get yours at: https://console.groq.com/keys (free tier is sufficient for the course)

# --- Required from Session 4 (LangSmith tracing starts with US-03) ---
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=batch1-wealthdesk
LANGSMITH_TRACING=true                 # optional -- set to false to disable tracing without removing the key
# Get yours at: https://smith.langchain.com (free tier covers the full course)

# --- Required from Session 6 (evaluation judge) ---
OPENAI_API_KEY=your_openai_api_key_here
# Used ONLY for the LLM-as-judge eval (GPT-4o-mini). Not used by the WealthDesk agent itself.
# Very low cost -- the eval dataset has 40 questions and runs 3 times per session.
